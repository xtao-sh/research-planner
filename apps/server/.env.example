DATABASE_URL="file:./dev.db"

# Bind address for the HTTP server. Defaults to 127.0.0.1 (loopback only) so
# single-user installs aren't reachable from the LAN. Set HOST=0.0.0.0 to bind
# all interfaces (e.g. behind a reverse proxy in a multi-user deploy).
# HOST=127.0.0.1

# Multi-user mode. Defaults to 0 (single-user local mode), which:
#   - returns 410 Gone from /api/auth/register|login|logout
#   - returns 410 Gone from the entire /api/invites/* flow + email-invite
#     branch of POST /api/workspaces/:id/members
#   - rejects non-loopback /ws/workspace/:id connections with close 4403
# Flip to 1 to re-enable for a real deployment. Note: the matching frontend
# routes (e.g. <AcceptInvite>) were removed and must be restored if you flip
# this on.
# MULTI_USER=0

# Comma-separated list of additional allowed origins for CORS. In production
# this is the entire allowlist (the dev defaults aren't merged in). In dev
# the dev defaults (localhost:3060, 127.0.0.1:3060, localhost:5173,
# 127.0.0.1:5173) are always allowed; CORS_ORIGIN extends them.
# CORS_ORIGIN=https://app.example.com,https://staging.example.com
