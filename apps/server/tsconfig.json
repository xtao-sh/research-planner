{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@rp/shared": ["../../packages/shared/src/types/index.ts"],
      "@rp/shared/*": ["../../packages/shared/src/*"],
      "@rp/scheduler": ["../../packages/scheduler/src/index.ts"],
      "@rp/scheduler/*": ["../../packages/scheduler/src/*"]
    }
  },
  "include": ["src"]
}
