{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ES2020",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@rp/shared": ["../../packages/shared/src/types/index.ts"],
      "@rp/shared/*": ["../../packages/shared/src/*"],
      "@rp/scheduler": ["../../packages/scheduler/src/index.ts"],
      "@rp/scheduler/*": ["../../packages/scheduler/src/*"]
    }
  },
  "include": ["src", "vite-env.d.ts"]
}
